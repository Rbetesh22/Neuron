# ── LLM ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=                          # optional fallback

# ── Canvas LMS ─────────────────────────────────────────────────────────────────
CANVAS_API_TOKEN=your_token_here
CANVAS_API_URL=https://canvas.youruniversity.edu/api/v1

# ── Notion ─────────────────────────────────────────────────────────────────────
NOTION_API_TOKEN=                        # notion.so/my-integrations

# ── Readwise ───────────────────────────────────────────────────────────────────
READWISE_API_TOKEN=                      # readwise.io/access_token

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=                            # github.com/settings/tokens

# ── Google (Calendar, Gmail, Drive) ────────────────────────────────────────────
GOOGLE_CLIENT_ID=                        # console.cloud.google.com → OAuth 2.0 Client ID (Desktop)
GOOGLE_CLIENT_SECRET=

# ── Spotify ────────────────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=                       # developer.spotify.com/dashboard
SPOTIFY_CLIENT_SECRET=                   # redirect URI: http://localhost:8888/callback

# ── Pocket ─────────────────────────────────────────────────────────────────────
POCKET_CONSUMER_KEY=                     # getpocket.com/developer
POCKET_ACCESS_TOKEN=

# ── Trakt ──────────────────────────────────────────────────────────────────────
TRAKT_CLIENT_ID=                         # trakt.tv/oauth/applications
TRAKT_USERNAME=
